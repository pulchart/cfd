####################################################################################
# CFD Kickstart ROM - 1 MB AmigaOS 3.1 for {{ model }}
####################################################################################

{% from "_render_modules.j2" import render_modules -%}

# --------------------------------------------------------------------------
# F8 ROM (0xF80000) - 3.1 source + 1Mb_Scantable chunk
# --------------------------------------------------------------------------

auditfiles ROMs
var SOURCEROM "${{ sourcerom_crc }}"

newrom 512k 255
rombase 0xF80000

add "$SOURCEROM" exec.library
add "Components/BinaryChunks/1Mb_Scantable.bin"

# Locate the 3.1 scantable inside exec.library and patch the two LEA(PC),A0
# opcodes that reference it so they point to the new chunk instead.
find $exec.library 0x00F800000100000000F0000000F80000FFFFFFFF
var FIND add $ROMBASE
var FIND mid 4
var OPCODE "LEA $FIND(PC),A0"
findopcode $exec.library "$OPCODE"
var FIND add 2
var REL $1Mb_Scantable.bin.(START)
var REL subtract $FIND
var REL mid 6
patch $FIND 0x$REL
findopcode $exec.library "$OPCODE"
var FIND add 2
var REL $1Mb_Scantable.bin.(START)
var REL subtract $FIND
var REL mid 6
patch $FIND 0x$REL

# Add each original 3.1 module explicitly in its natural ROM order, with any
# patched module substituted for its replacement file (driven by `replace`/`with`
# rows in kickstart.yaml.
{% if model == "A600-3.1" %}
{% set stock_modules = [
    "audio.device", "gameport.device", "graphics.library", "dos.library",
    "filesystem", "console.device", "layers.library", "scsi.device",
    "con-handler", "bootmenu", "timer.device", "expansion.library",
    "utility.library", "battclock.resource", "carddisk.device",
    "cia.resource", "FileSystem.resource", "battmem.resource",
    "potgo.resource", "misc.resource", "workbench.task", "disk.resource",
    "ramdrive.device", "mathffp.library", "keymap.library", "romboot",
    "card.resource", "mathieeesingbas.library", "trackdisk.device",
    "icon.library", "ram-handler", "shell", "intuition.library",
    "gadtools.library", "workbench.library", "ramlib"
] %}
{% elif model == "A1200-3.1" %}
{% set stock_modules = [
    "expansion.library", "romboot", "graphics.library", "dos.library",
    "filesystem", "console.device", "layers.library", "scsi.device",
    "con-handler", "gameport.device", "audio.device", "card.resource",
    "utility.library", "battclock.resource", "carddisk.device",
    "ramlib", "ramdrive.device", "cia.resource", "potgo.resource",
    "misc.resource", "workbench.task", "FileSystem.resource",
    "disk.resource", "mathffp.library", "timer.device",
    "mathieeesingbas.library", "keymap.library", "bootmenu",
    "trackdisk.device", "icon.library", "ram-handler", "shell",
    "intuition.library", "gadtools.library", "workbench.library",
    "battmem.resource"
] %}
{% endif %}

{% for mod in stock_modules %}
{%- if mod in patched_modules %}
{{ patched_modules[mod] }}
{%- else %}
add "$SOURCEROM" {{ mod }}
{%- endif %}
{% endfor %}

{{ render_modules(f8_modules) }}
add checksum
add size
add vectors
checksum

saverom {{ outdir }}/cfd.F8

# --------------------------------------------------------------------------
# E0 ROM (0xE00000) - extra modules
# --------------------------------------------------------------------------

newrom 512k 255
rombase 0xE00000

add "Components/BinaryChunks/ROMHeader_E0"

{{ render_modules(e0_modules) }}
add checksum
add size
add vectors
checksum

saverom {{ outdir }}/cfd.E0

# --------------------------------------------------------------------------
# Optional: byteswapped 512 KB halves for dual-chip EPROM burning
# --------------------------------------------------------------------------

{% if saveprofile %}{{ saveprofile }}
{% endif %}
exit

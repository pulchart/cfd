####################################################################################
# CFD Kickstart ROM - 1 MB AmigaOS {{ os }} for {{ model }}
####################################################################################

{% from "_render_modules.j2" import render_modules -%}

# --------------------------------------------------------------------------
# F8 ROM (0xF80000) - {{ os }} source + 1Mb_Scantable chunk
# --------------------------------------------------------------------------

auditfiles ROMs
var SOURCEROM "${{ sourcerom_crc }}"

newrom 512k 255
rombase 0xF80000

add "$SOURCEROM" exec.library
add "Components/BinaryChunks/1Mb_Scantable.bin"

# 2.0x exec.library (v37) carries two independent 24-byte scantables (same byte
# pattern), each referenced by its own LEA(PC),A0 opcode.  Redirect each
# LEA at the new chunk in turn.

# First scantable + its LEA reference.
find $exec.library 0x00F800000100000000F0000000F80000FFFFFFFF
var FIND add $ROMBASE
var FIND mid 4
var OPCODE "LEA $FIND(PC),A0"
findopcode $exec.library "$OPCODE"
var FIND add 2
var REL $1Mb_Scantable.bin.(START)
var REL subtract $FIND
var REL mid 6
patch $FIND 0x$REL

# Step past the first scantable match to find the second one (same byte
# pattern, later in exec.library), then patch its LEA reference.
find $exec.library 0x00F800000100000000F0000000F80000FFFFFFFF
var FIND add 2
find $FIND $exec.library.(END) 0x00F800000100000000F0000000F80000FFFFFFFF
var FIND add $ROMBASE
var FIND mid 4
var OPCODE "LEA $FIND(PC),A0"
findopcode $exec.library "$OPCODE"
var FIND add 2
var REL $1Mb_Scantable.bin.(START)
var REL subtract $FIND
var REL mid 6
patch $FIND 0x$REL

{% if model == "A600-2.05" %}
{% set stock_modules = [
    "expansion.library", "mathieeesingbas.library", "carddisk.device", "scsi.device",
    "audio.device", "battclock.resource", "battmem.resource", "con-handler",
    "console.device", "disk.resource", "dos.library", "FileSystem.resource",
    "potgo.resource", "filesystem", "gadtools.library", "icon.library",
    "mathffp.library", "graphics.library", "bootmenu", "cia.resource",
    "card.resource", "intuition.library", "keymap.library", "layers.library",
    "misc.resource", "ram-handler", "ramdrive.device", "ramlib",
    "gameport.device", "shell", "romboot", "timer.device",
    "trackdisk.device", "utility.library", "workbench.task", "workbench.library"
] %}
{% elif model == "A500plus-2.04" %}
{% set stock_modules = [
    "expansion.library", "audio.device", "battclock.resource", "battmem.resource",
    "bootmenu", "cia.resource", "con-handler", "console.device",
    "disk.resource", "dos.library", "FileSystem.resource", "filesystem",
    "keymap.library", "workbench.task", "graphics.library", "gadtools.library",
    "icon.library", "layers.library", "mathffp.library", "mathieeesingbas.library",
    "misc.resource", "ramdrive.device", "ramlib", "gameport.device",
    "shell", "romboot", "timer.device", "trackdisk.device",
    "ram-handler", "potgo.resource", "utility.library", "intuition.library",
    "workbench.library"
] %}
{% endif %}

{% for mod in stock_modules %}
{%- if mod in patched_modules %}
{{ patched_modules[mod] }}
{%- else %}
add "$SOURCEROM" {{ mod }}
{%- endif %}
{% endfor %}

{{ render_modules(f8_modules) }}
add checksum
add size
add vectors
checksum

saverom {{ outdir }}/cfd.F8

# --------------------------------------------------------------------------
# E0 ROM (0xE00000) - extra modules
# --------------------------------------------------------------------------

newrom 512k 255
rombase 0xE00000

add "Components/BinaryChunks/ROMHeader_E0"

{{ render_modules(e0_modules) }}
add checksum
add size
add vectors
checksum

saverom {{ outdir }}/cfd.E0

# --------------------------------------------------------------------------
# Optional: byteswapped 512 KB halves for dual-chip EPROM burning
# --------------------------------------------------------------------------

{% if saveprofile %}{{ saveprofile }}
{% endif %}
exit
